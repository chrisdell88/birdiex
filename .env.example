# DataGolf API — request a key at https://datagolf.com (account page)
# Rate limit: 45 req/min. Never commit this file with a real value.
DATAGOLF_API_KEY=your_datagolf_api_key_here

# --- Alerts feature (signup page + email/Discord notifications) ---
# Full setup walkthrough: docs/ALERTS_SETUP.md

# Supabase — the subscriber database.
# VITE_ vars are exposed to the browser (safe: the anon key is public by design).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
# Server-only — used by scripts/notify.ts. NEVER prefix this with VITE_.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Resend — sends the alert emails. Free tier: 3,000/month.
RESEND_API_KEY=your_resend_api_key
RESEND_FROM=BirdieX <alerts@birdiex.co>

# Discord — webhook URL for the channel that picks post to.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# Public invite link shown on the signup page's "Join Discord" button.
VITE_DISCORD_INVITE_URL=https://discord.gg/your-invite

# Optional — defaults to https://birdiex.co
SITE_URL=https://birdiex.co
